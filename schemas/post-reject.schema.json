{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["status", "reason"],
  "properties": {
    "status": {
      "type": "string",
      "const": "NOT_APPROVED"
    },
    "reason": {
      "type": "integer",
      "minimum": 1
    }
  }
}
