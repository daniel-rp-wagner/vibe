{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["status"],
  "properties": {
    "status": {
      "type": "string",
      "const": "APPROVED"
    },
    "criteria": {
      "type": "array",
      "items": {
        "type": "integer",
        "minimum": 1
      },
      "uniqueItems": true
    },
    "store_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^\\d{4}$"
      },
      "minItems": 1,
      "uniqueItems": true
    }
  }
}
